// ARKSA_ServerMaintainer — Slint UI (Phase 4).
//
// Two top-level windows:
//   - MainWindow:        profile picker, status, lifecycle, RCON, log
//   - NewProfileWindow:  modal-style dialog for creating a brand-new profile
//
// All numeric → string conversion happens in Rust before properties are set,
// so this file deals only in strings/bools/ints.

import {
    Button, CheckBox, ComboBox, GroupBox, HorizontalBox, LineEdit,
    ListView, ScrollView, SpinBox, StandardListView, TabWidget,
    TextEdit, VerticalBox
} from "std-widgets.slint";

export struct ServerStatusView {
    running: bool,
    title: string,
    map: string,
    ports: string,
    memory: string,
    uptime: string,
}

/// Translated UI strings. Populated from Rust at startup based on
/// `AppSettings::language()`. Live language switching requires a restart.
export struct UiLabels {
    main_window_title: string,
    arksa_dir: string,
    btn_browse: string,
    profile_label: string,
    btn_new: string,
    btn_find: string,
    btn_notifications: string,
    btn_refresh: string,
    panel_server_status: string,
    label_status: string,
    label_map: string,
    label_ports: string,
    label_memory: string,
    label_uptime: string,
    btn_start: string,
    btn_stop: string,
    btn_restart: string,
    btn_install: string,
    panel_rcon: string,
    placeholder_rcon: string,
    btn_send: string,
    panel_log: string,
    empty_title: string,
    empty_subtitle: string,
    empty_create_first: string,
    status_stopped: string,
    status_no_profile: string,
    status_profile_error: string,
    find_window_title: string,
    find_category: string,
    find_filter: string,
    find_filter_placeholder: string,
    find_col_name: string,
    find_col_class: string,
    find_col_info: string,
    new_profile_window_title: string,
    notifications_window_title: string,
    notif_section_discord: string,
    notif_webhook_url: string,
    notif_display_name: string,
    notif_btn_test: string,
    notif_section_tray: string,
    notif_tray_enabled_text: string,
    notif_section_events: string,
    notif_section_language: string,
    notif_btn_save: string,
    notif_btn_cancel: string,
    btn_world_settings: string,
    world_window_title: string,
    world_tab_rates: string,
    world_tab_day: string,
    world_tab_player: string,
    world_tab_tamed: string,
    world_tab_wild: string,
    world_tab_difficulty: string,
    world_tab_pvp: string,
    world_tab_ops: string,
    world_tab_breeding: string,
    world_tab_loot: string,
    world_tab_stats: string,
    world_tab_combat: string,
    world_tab_xp: string,
    world_tab_chat: string,
    world_tab_cluster: string,
    world_tab_clamps: string,
    world_tab_flags: string,
    world_btn_import: string,
    world_btn_reset: string,
    world_btn_save: string,
    world_btn_cancel: string,
    world_hint: string,
}

// ─── Main window ───────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: root.labels.main_window_title;
    preferred-width: 860px;
    preferred-height: 680px;
    min-width: 540px;
    min-height: 440px;

    in property <UiLabels> labels;
    in property <[string]> profile-names: [];
    in-out property <int> selected-profile-index: 0;
    in property <ServerStatusView> status: {
        running: false,
        title: "(no profile loaded)",
        map: "—",
        ports: "—",
        memory: "—",
        uptime: "—",
    };
    in property <string> log-text: "";
    in property <string> install-dir: "(unknown)";
    in-out property <string> rcon-input: "";
    in property <bool> action-busy: false;

    callback profile-selected(int);
    callback start-server();
    callback stop-server();
    callback restart-server();
    callback refresh-status();
    callback send-rcon();
    callback browse-install-dir();
    callback new-profile();
    callback install-update-server();
    callback open-find();
    callback open-notifications();
    callback open-world-settings();

    VerticalBox {
        padding: 12px;
        spacing: 10px;

        // Top bar: ARKSA install dir
        HorizontalBox {
            spacing: 8px;
            Text { text: root.labels.arksa_dir; vertical-alignment: center; }
            Text {
                text: root.install-dir;
                vertical-alignment: center;
                horizontal-stretch: 1;
                overflow: elide;
            }
            Button {
                text: root.labels.btn_browse;
                enabled: !root.action-busy;
                clicked => { root.browse-install-dir(); }
            }
        }

        // Profile row
        HorizontalBox {
            spacing: 8px;
            Text { text: root.labels.profile_label; vertical-alignment: center; }
            ComboBox {
                model: root.profile-names;
                current-index <=> root.selected-profile-index;
                horizontal-stretch: 1;
                enabled: !root.action-busy && root.profile-names.length > 0;
                selected => { root.profile-selected(self.current-index); }
            }
            Button {
                text: root.labels.btn_new;
                enabled: !root.action-busy;
                clicked => { root.new-profile(); }
            }
            Button {
                text: root.labels.btn_find;
                enabled: !root.action-busy;
                clicked => { root.open-find(); }
            }
            Button {
                text: root.labels.btn_world_settings;
                // Editing Game.ini / GameUserSettings.ini only makes sense
                // for a real profile; greyed out otherwise.
                enabled: !root.action-busy && root.profile-names.length > 0;
                clicked => { root.open-world-settings(); }
            }
            Button {
                text: root.labels.btn_notifications;
                enabled: !root.action-busy;
                clicked => { root.open-notifications(); }
            }
            Button {
                text: root.labels.btn_refresh;
                enabled: !root.action-busy;
                clicked => { root.refresh-status(); }
            }
        }

        // Empty state vs. populated state
        if root.profile-names.length == 0: VerticalBox {
            alignment: center;
            spacing: 12px;
            vertical-stretch: 1;
            Text {
                text: root.labels.empty_title;
                font-size: 18px;
                horizontal-alignment: center;
            }
            Text {
                text: root.labels.empty_subtitle;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            HorizontalBox {
                alignment: center;
                Button {
                    text: root.labels.empty_create_first;
                    enabled: !root.action-busy;
                    clicked => { root.new-profile(); }
                }
            }
        }

        if root.profile-names.length > 0: GroupBox {
            title: root.labels.panel_server_status;
            VerticalBox {
                spacing: 4px;
                Text { text: root.labels.label_status + " " + root.status.title; }
                Text { text: root.labels.label_map + " " + root.status.map; }
                Text { text: root.labels.label_ports + " " + root.status.ports; }
                Text { text: root.labels.label_memory + " " + root.status.memory; }
                Text { text: root.labels.label_uptime + " " + root.status.uptime; }
            }
        }

        if root.profile-names.length > 0: HorizontalBox {
            alignment: start;
            spacing: 8px;
            Button {
                text: root.labels.btn_start;
                enabled: !root.action-busy && !root.status.running;
                clicked => { root.start-server(); }
            }
            Button {
                text: root.labels.btn_stop;
                enabled: !root.action-busy && root.status.running;
                clicked => { root.stop-server(); }
            }
            Button {
                text: root.labels.btn_restart;
                enabled: !root.action-busy && root.status.running;
                clicked => { root.restart-server(); }
            }
            Button {
                text: root.labels.btn_install;
                enabled: !root.action-busy && !root.status.running;
                clicked => { root.install-update-server(); }
            }
        }

        if root.profile-names.length > 0: GroupBox {
            title: root.labels.panel_rcon;
            HorizontalBox {
                spacing: 6px;
                LineEdit {
                    placeholder-text: root.labels.placeholder_rcon;
                    text <=> root.rcon-input;
                    horizontal-stretch: 1;
                    enabled: !root.action-busy && root.status.running;
                    accepted => { root.send-rcon(); }
                }
                Button {
                    text: root.labels.btn_send;
                    enabled: !root.action-busy && root.status.running;
                    clicked => { root.send-rcon(); }
                }
            }
        }

        GroupBox {
            title: root.labels.panel_log;
            vertical-stretch: 1;
            TextEdit {
                text: root.log-text;
                read-only: true;
                wrap: word-wrap;
            }
        }
    }
}

// ─── World settings dialog ────────────────────────────────────────────────

/// One labelled float row used inside the World Settings tabs. Keeps the
/// per-field markup short so the window definition below stays scannable.
component WorldFloatRow inherits HorizontalBox {
    in property <string> label;
    in-out property <string> value;
    spacing: 8px;
    Text {
        text: label;
        min-width: 320px;
        vertical-alignment: center;
    }
    LineEdit {
        text <=> root.value;
        horizontal-stretch: 1;
        input-type: text;
    }
}

component WorldBoolRow inherits HorizontalBox {
    in property <string> label;
    in-out property <bool> value;
    spacing: 8px;
    Text {
        text: label;
        min-width: 320px;
        vertical-alignment: center;
    }
    CheckBox {
        checked <=> root.value;
        horizontal-stretch: 1;
    }
}

export component WorldSettingsWindow inherits Window {
    title: root.labels.world_window_title;
    preferred-width: 720px;
    preferred-height: 640px;
    min-width: 580px;
    min-height: 480px;

    in property <UiLabels> labels;
    in property <string> validation-error: "";
    in property <bool> busy: false;

    // Field properties — strings for floats so we can validate / format on
    // the Rust side, bools for booleans. Each is grouped by tab.

    // Rates
    in-out property <string> f_xp_multiplier: "1.0";
    in-out property <string> f_harvest_amount_multiplier: "1.0";
    in-out property <string> f_harvest_health_multiplier: "1.0";
    in-out property <string> f_resources_respawn_period_multiplier: "1.0";
    in-out property <string> f_taming_speed_multiplier: "1.0";
    in-out property <string> f_mating_interval_multiplier: "1.0";
    in-out property <string> f_egg_hatch_speed_multiplier: "1.0";
    in-out property <string> f_baby_mature_speed_multiplier: "1.0";

    // Day cycle
    in-out property <string> f_day_cycle_speed_scale: "1.0";
    in-out property <string> f_day_time_speed_scale: "1.0";
    in-out property <string> f_night_time_speed_scale: "1.0";

    // Player
    in-out property <string> f_player_food: "1.0";
    in-out property <string> f_player_water: "1.0";
    in-out property <string> f_player_stamina: "1.0";
    in-out property <string> f_player_health_recovery: "1.0";
    in-out property <string> f_player_damage: "1.0";
    in-out property <string> f_player_resistance: "1.0";
    in-out property <string> f_player_harvesting: "1.0";

    // Tamed dino
    in-out property <string> f_dino_food: "1.0";
    in-out property <string> f_dino_stamina: "1.0";
    in-out property <string> f_dino_health_recovery: "1.0";
    in-out property <string> f_tamed_damage: "1.0";
    in-out property <string> f_tamed_resistance: "1.0";

    // Wild dino
    in-out property <string> f_wild_food: "1.0";
    in-out property <string> f_wild_stamina: "1.0";
    in-out property <string> f_wild_torpor: "1.0";
    in-out property <string> f_dino_count: "1.0";

    // Difficulty / structure
    in-out property <string> f_difficulty_offset: "0.2";
    in-out property <string> f_override_official_difficulty: "5.0";
    in-out property <string> f_structure_damage: "1.0";
    in-out property <string> f_structure_resistance: "1.0";
    in-out property <string> f_structure_repair_cooldown: "180.0";
    in-out property <bool> b_disable_imprint_dino_buff: false;
    in-out property <bool> b_allow_anyone_baby_imprint: false;

    // Phase 8b — PvE/PvP toggles
    in-out property <bool> b_server_pve: false;
    in-out property <bool> b_allow_flyer_carry_pve: false;
    in-out property <bool> b_enable_cryo_sickness_pve: false;
    in-out property <bool> b_disable_structure_decay_pve: false;

    // Phase 8b — Operations basics
    in-out property <string> f_max_tamed_dinos: "5000.0";
    in-out property <string> f_kick_idle_players_period: "3600.0";
    in-out property <string> f_auto_save_period_minutes: "15.0";
    in-out property <string> f_the_max_structures_in_range: "10500";

    // Phase 8c — Breeding / Imprint
    in-out property <string> f_mating_speed_multiplier: "1.0";
    in-out property <string> f_lay_egg_interval_multiplier: "1.0";
    in-out property <string> f_passive_tame_interval_multiplier: "1.0";
    in-out property <string> f_baby_food_consumption_speed_multiplier: "1.0";
    in-out property <string> f_baby_imprint_amount_multiplier: "1.0";
    in-out property <string> f_baby_imprinting_stat_scale_multiplier: "1.0";
    in-out property <string> f_baby_cuddle_interval_multiplier: "1.0";
    in-out property <string> f_baby_cuddle_grace_period_multiplier: "1.0";
    in-out property <string> f_baby_cuddle_lose_imprint_quality_speed_multiplier: "1.0";
    in-out property <bool> b_disable_dino_breeding: false;
    in-out property <bool> b_disable_dino_taming: false;

    // Phase 8d — Loot / Spoilage
    in-out property <string> f_supply_crate_loot_quality_multiplier: "1.0";
    in-out property <string> f_fishing_loot_quality_multiplier: "1.0";
    in-out property <string> f_crop_decay_speed_multiplier: "1.0";
    in-out property <string> f_crop_growth_speed_multiplier: "1.0";
    in-out property <bool> b_disable_loot_crates: false;
    in-out property <string> f_limit_non_player_dropped_items_count: "0";
    in-out property <string> f_limit_non_player_dropped_items_range: "0";
    in-out property <string> f_global_item_decomposition_time_multiplier: "1.0";
    in-out property <string> f_global_spoiling_time_multiplier: "1.0";
    in-out property <string> f_global_corpse_decomposition_time_multiplier: "1.0";
    in-out property <string> f_use_corpse_life_span_multiplier: "1.0";
    in-out property <bool> b_use_corpse_locator: true;
    in-out property <string> f_poop_interval_multiplier: "1.0";
    in-out property <string> f_fuel_consumption_interval_multiplier: "1.0";
    in-out property <string> f_max_fall_speed_multiplier: "1.0";

    // Phase 8e — Stat arrays (PerLevelStatsMultiplier_* + PlayerBaseStatMultipliers)
    // Indices: 0=Health 1=Stamina 2=Torpidity 3=Oxygen 4=Food 5=Water
