    in-out property <string> f_override_max_experience_points_player: "0";
    in-out property <string> f_override_max_experience_points_dino: "0";

    // Phase 8h — Cosmetic / Chat
    in-out property <bool> b_global_voice_chat: false;
    in-out property <bool> b_proximity_chat: false;
    in-out property <bool> b_dont_always_notify_player_joined: false;
    in-out property <bool> b_always_notify_player_left: false;
    in-out property <bool> b_admin_logging: false;
    in-out property <bool> b_allow_hide_damage_source_from_logs: false;
    in-out property <bool> b_show_floating_damage_text: false;
    in-out property <bool> b_show_map_player_location: true;
    in-out property <bool> b_server_crosshair: true;
    in-out property <bool> b_server_force_no_hud: false;
    in-out property <bool> b_allow_third_person_player: true;
    in-out property <bool> b_allow_hit_markers: true;
    in-out property <bool> b_disable_pve_gamma: false;
    in-out property <bool> b_enable_pvp_gamma: false;

    callback import-clicked();
    callback reset-clicked();
    callback save-clicked();
    callback cancel-clicked();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.labels.world_hint;
            wrap: word-wrap;
        }

        HorizontalBox {
            alignment: start;
            spacing: 8px;
            Button {
                text: root.labels.world_btn_import;
                enabled: !root.busy;
                clicked => { root.import-clicked(); }
            }
            Button {
                text: root.labels.world_btn_reset;
                enabled: !root.busy;
                clicked => { root.reset-clicked(); }
            }
        }

        TabWidget {
            vertical-stretch: 1;

            Tab {
                title: root.labels.world_tab_rates;
                ScrollView {
                    VerticalBox {
                        padding: 8px;
                        spacing: 4px;
                        WorldFloatRow { label: "XPMultiplier";                       value <=> root.f_xp_multiplier; }
                        WorldFloatRow { label: "HarvestAmountMultiplier";            value <=> root.f_harvest_amount_multiplier; }
                        WorldFloatRow { label: "HarvestHealthMultiplier";            value <=> root.f_harvest_health_multiplier; }
                        WorldFloatRow { label: "ResourcesRespawnPeriodMultiplier";   value <=> root.f_resources_respawn_period_multiplier; }
                        WorldFloatRow { label: "TamingSpeedMultiplier";              value <=> root.f_taming_speed_multiplier; }
                        WorldFloatRow { label: "MatingIntervalMultiplier";           value <=> root.f_mating_interval_multiplier; }
                        WorldFloatRow { label: "EggHatchSpeedMultiplier";            value <=> root.f_egg_hatch_speed_multiplier; }
                        WorldFloatRow { label: "BabyMatureSpeedMultiplier";          value <=> root.f_baby_mature_speed_multiplier; }
