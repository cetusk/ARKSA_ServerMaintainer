// ARKSA_ServerMaintainer — Slint UI (Phase 4).
//
// Two top-level windows:
//   - MainWindow:        profile picker, status, lifecycle, RCON, log
//   - NewProfileWindow:  modal-style dialog for creating a brand-new profile
//
// All numeric → string conversion happens in Rust before properties are set,
// so this file deals only in strings/bools/ints.

import {
    Button, CheckBox, ComboBox, GroupBox, HorizontalBox, LineEdit,
    ListView, Palette, ScrollView, SpinBox, StandardListView, TabWidget,
    TextEdit, VerticalBox
} from "std-widgets.slint";

/// Project-wide accent palette layered on top of Slint's `Palette` dark
/// mode. We pick a turquoise / teal blue so the GUI has its own visual
/// identity while still feeling at home in dark mode. Standard Slint
/// widgets (Button, ComboBox, LineEdit) keep their default styling — only
/// our custom components (SectionGroup headers, CategoryButton highlight,
/// LabelCell ⓘ marker, popup borders, etc.) switch to AppTheme.
export global AppTheme {
    out property <color> accent: #1ABC9C;          // turquoise
    out property <color> accent-hover: #16A085;
    out property <color> accent-soft: #1ABC9C40;   // ~25% alpha
    out property <color> header-bg: #0F2A2E;       // very dark teal
    out property <color> header-fg: #1ABC9C;       // turquoise text
    out property <color> border: #1ABC9C66;        // turquoise w/ alpha
    out property <color> on-accent: #0E2628;       // dark text on accent bg
}

/// Sectioned content block. Renders a turquoise-accented header bar with
/// `title` on top and the slot's children below in a padded panel. Used
/// across the main window so visually-distinct sections (Setup / Profile /
/// Server status / RCON / Log) all share the same look.
component SectionGroup inherits VerticalBox {
    in property <string> title;
    spacing: 0;
    padding: 0;

    Rectangle {
        height: 28px;
        background: AppTheme.header-bg;
        border-top-left-radius: 6px;
        border-top-right-radius: 6px;
        border-color: AppTheme.border;
        border-width: 1px;
        HorizontalBox {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 0;
            padding-bottom: 0;
            Text {
                text: root.title;
                color: AppTheme.header-fg;
                font-weight: 700;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }
    }
    Rectangle {
        background: Palette.alternate-background;
        border-bottom-left-radius: 6px;
        border-bottom-right-radius: 6px;
        border-color: AppTheme.border;
        border-width: 1px;
        VerticalBox {
            padding: 8px;
            spacing: 6px;
            @children
        }
    }
}

export struct ServerStatusView {
    running: bool,
    title: string,
    map: string,
    ports: string,
    memory: string,
    uptime: string,
}

/// Translated UI strings. Populated from Rust at startup based on
/// `AppSettings::language()`. Live language switching requires a restart.
export struct UiLabels {
    main_window_title: string,
    main_language_label: string,
    section_setup: string,
    section_profile: string,
    section_lifecycle: string,
    section_tools: string,
    profile_hint: string,
    profile_path_label: string,
    arksa_dir: string,
    btn_browse: string,
    profile_label: string,
    btn_new: string,
    btn_find: string,
    btn_notifications: string,
    btn_refresh: string,
    panel_server_status: string,
    label_status: string,
    label_map: string,
    label_ports: string,
    label_memory: string,
    label_uptime: string,
    btn_start: string,
    btn_stop: string,
    btn_restart: string,
    btn_install: string,
    panel_rcon: string,
    placeholder_rcon: string,
    btn_send: string,
    panel_log: string,
    empty_title: string,
    empty_subtitle: string,
    empty_create_first: string,
    status_stopped: string,
    status_no_profile: string,
    status_profile_error: string,
    find_window_title: string,
    find_category: string,
    find_filter: string,
    find_filter_placeholder: string,
    find_col_name: string,
    find_col_class: string,
    find_col_info: string,
    new_profile_window_title: string,
    notifications_window_title: string,
    notif_section_discord: string,
    notif_webhook_url: string,
    notif_display_name: string,
    notif_btn_test: string,
    notif_section_tray: string,
    notif_tray_enabled_text: string,
    notif_section_events: string,
    notif_section_language: string,
    notif_btn_save: string,
    notif_btn_cancel: string,
    btn_world_settings: string,
    world_window_title: string,
    world_tab_rates: string,
    world_tab_day: string,
    world_tab_player: string,
    world_tab_tamed: string,
    world_tab_wild: string,
    world_tab_difficulty: string,
    world_tab_pvp: string,
    world_tab_ops: string,
    world_tab_breeding: string,
    world_tab_loot: string,
    world_tab_stats: string,
    world_tab_combat: string,
    world_tab_xp: string,
    world_tab_chat: string,
    world_tab_cluster: string,
    world_tab_clamps: string,
    world_tab_flags: string,
    world_btn_import: string,
    world_btn_reset: string,
    world_btn_save: string,
    world_btn_cancel: string,
    world_hint: string,
    world_col_param: string,
    world_col_value: string,
    world_col_category: string,
}

// ─── Main window ───────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: root.labels.main_window_title;
    preferred-width: 860px;
    preferred-height: 680px;
    min-width: 540px;
    min-height: 440px;
    background: Palette.background;

    /// Force every Slint widget into dark mode. Done in `init` so all child
    /// Windows that inherit the same Palette singleton (notifications, world
    /// settings, find, new profile) follow suit without per-window code.
    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    in property <UiLabels> labels;
    in property <[string]> profile-names: [];
    in-out property <int> selected-profile-index: 0;
    /// Full filesystem path of the currently-selected profile's `.ini`.
    /// Updated from Rust whenever the selection changes so the UI can
    /// surface "you are about to edit *this* file".
    in property <string> selected-profile-path: "";
    in property <ServerStatusView> status: {
        running: false,
        title: "(no profile loaded)",
        map: "—",
        ports: "—",
        memory: "—",
        uptime: "—",
    };
    in property <string> log-text: "";
    in property <string> install-dir: "(unknown)";
    in-out property <string> rcon-input: "";
    in property <bool> action-busy: false;
    /// Languages dropdown content + selected index.
    in property <[string]> language-options: ["Auto", "English", "日本語"];
    in-out property <int> language-index: 0;

    callback profile-selected(int);
    callback start-server();
    callback stop-server();
    callback restart-server();
    callback refresh-status();
    callback send-rcon();
    callback browse-install-dir();
    callback new-profile();
    callback install-update-server();
    callback open-find();
    callback open-notifications();
    callback open-world-settings();
    callback language-changed(int);

    ScrollView {
        // The overall window can be resized smaller than its contents
        // (six SectionGroups + a chunky Log textarea). Wrap everything
        // in a ScrollView so nothing gets cropped at narrow window sizes.
        VerticalBox {
            padding: 12px;
            spacing: 8px;

        // ── Setup section ──────────────────────────────────────────────
        // Tool data dir + UI language live here together with global
        // tools that don't depend on which profile is selected
        // (Find / Notifications).
        SectionGroup {
            title: root.labels.section_setup;
            HorizontalBox {
                spacing: 8px;
                Text { text: root.labels.arksa_dir; vertical-alignment: center; }
                Text {
                    text: root.install-dir;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Button {
                    text: root.labels.btn_browse;
                    enabled: !root.action-busy;
                    clicked => { root.browse-install-dir(); }
                }
                Text {
                    text: root.labels.main_language_label;
                    vertical-alignment: center;
                }
                ComboBox {
                    model: root.language-options;
                    current-index <=> root.language-index;
                    enabled: !root.action-busy;
                    selected => { root.language-changed(self.current-index); }
                }
            }
            HorizontalBox {
                spacing: 8px;
                alignment: end;
                Text {
                    text: root.labels.section_tools;
                    color: AppTheme.accent;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                Button {
                    text: root.labels.btn_find;
                    enabled: !root.action-busy;
                    clicked => { root.open-find(); }
                }
                Button {
                    text: root.labels.btn_notifications;
                    enabled: !root.action-busy;
                    clicked => { root.open-notifications(); }
                }
            }
        }

        // ── Profile section ────────────────────────────────────────────
        // Top sub-row: pick OR create a profile (these both manage the
        //              set of profiles, not the currently-selected one).
        // Hint + path:  explain what the dropdown items are and where
        //              the selected file lives on disk.
        // Bottom sub-row: actions that operate on the *selected* profile.
        SectionGroup {
            title: root.labels.section_profile;
            Text {
                text: root.labels.profile_hint;
                color: Palette.foreground;
                font-size: 11px;
                wrap: word-wrap;
            }
            HorizontalBox {
                spacing: 8px;
                Text { text: root.labels.profile_label; vertical-alignment: center; }
                ComboBox {
                    model: root.profile-names;
                    current-index <=> root.selected-profile-index;
                    // Cap width so a single profile name doesn't stretch
                    // the dropdown across the whole window.
                    max-width: 320px;
                    horizontal-stretch: 1;
                    enabled: !root.action-busy && root.profile-names.length > 0;
                    selected => { root.profile-selected(self.current-index); }
                }
                Button {
                    text: root.labels.btn_new;
                    enabled: !root.action-busy;
                    clicked => { root.new-profile(); }
                }
                // Spacer so the next thing is right-aligned.
                Rectangle { horizontal-stretch: 1; }
            }
            // "→ <full path>" so the user can confirm which file backs
            // the dropdown entry. Hidden when no profile is selected.
            if root.selected-profile-path != "": HorizontalBox {
                spacing: 6px;
                padding-left: 4px;
                Text {
                    text: "↳";
                    color: AppTheme.accent;
                    vertical-alignment: center;
                }
                Text {
                    text: root.labels.profile_path_label;
                    color: AppTheme.accent;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Text {
                    text: root.selected-profile-path;
                    color: Palette.foreground;
                    font-size: 11px;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
            }
            HorizontalBox {
                spacing: 8px;
                alignment: end;
                Button {
                    text: root.labels.btn_world_settings;
                    enabled: !root.action-busy && root.profile-names.length > 0;
                    clicked => { root.open-world-settings(); }
                }
            }
        }

        // ── Empty state when no profile exists ─────────────────────────
        if root.profile-names.length == 0: VerticalBox {
            alignment: center;
            spacing: 12px;
            vertical-stretch: 1;
            Text {
                text: root.labels.empty_title;
                font-size: 18px;
                horizontal-alignment: center;
            }
            Text {
                text: root.labels.empty_subtitle;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            HorizontalBox {
                alignment: center;
                Button {
                    text: root.labels.empty_create_first;
                    enabled: !root.action-busy;
                    clicked => { root.new-profile(); }
                }
            }
        }

        // ── Server status section ──────────────────────────────────────
        // Status text auto-refreshes every 5 s; the Refresh button lets
        // the user kick a manual poll without waiting.
        if root.profile-names.length > 0: SectionGroup {
            title: root.labels.panel_server_status;
            Text { text: root.labels.label_status + " " + root.status.title; }
            Text { text: root.labels.label_map + " " + root.status.map; }
            Text { text: root.labels.label_ports + " " + root.status.ports; }
            Text { text: root.labels.label_memory + " " + root.status.memory; }
            Text { text: root.labels.label_uptime + " " + root.status.uptime; }
            HorizontalBox {
                alignment: end;
                Button {
                    text: root.labels.btn_refresh;
                    enabled: !root.action-busy;
                    clicked => { root.refresh-status(); }
                }
            }
        }

        // ── Server control section ─────────────────────────────────────
        if root.profile-names.length > 0: SectionGroup {
            title: root.labels.section_lifecycle;
            HorizontalBox {
                alignment: start;
                spacing: 8px;
                Button {
                    text: root.labels.btn_start;
                    enabled: !root.action-busy && !root.status.running;
                    clicked => { root.start-server(); }
                }
                Button {
                    text: root.labels.btn_stop;
                    enabled: !root.action-busy && root.status.running;
                    clicked => { root.stop-server(); }
                }
                Button {
                    text: root.labels.btn_restart;
                    enabled: !root.action-busy && root.status.running;
                    clicked => { root.restart-server(); }
                }
                Button {
                    text: root.labels.btn_install;
                    enabled: !root.action-busy && !root.status.running;
                    clicked => { root.install-update-server(); }
                }
            }
        }

        // ── RCON section ───────────────────────────────────────────────
        if root.profile-names.length > 0: SectionGroup {
            title: root.labels.panel_rcon;
            HorizontalBox {
                spacing: 6px;
                LineEdit {
                    placeholder-text: root.labels.placeholder_rcon;
                    text <=> root.rcon-input;
                    horizontal-stretch: 1;
                    enabled: !root.action-busy && root.status.running;
                    accepted => { root.send-rcon(); }
                }
                Button {
                    text: root.labels.btn_send;
                    enabled: !root.action-busy && root.status.running;
                    clicked => { root.send-rcon(); }
                }
            }
        }

        // ── Log section ────────────────────────────────────────────────
        // Inside a ScrollView, vertical-stretch is meaningless — the log
        // area gets a fixed min-height so it remains usable without
        // collapsing to a single line.
        SectionGroup {
            title: root.labels.panel_log;
            TextEdit {
                text: root.log-text;
                read-only: true;
                wrap: word-wrap;
                min-height: 240px;
            }
        }
        }   // ── end VerticalBox inside ScrollView ──────────────────
    }       // ── end ScrollView ─────────────────────────────────────
}

// ─── World settings dialog ────────────────────────────────────────────────

/// Reusable label cell. When the row has a `description`, the label becomes
/// clickable: a hover underline + pointer cursor signal that more info is
/// available, and clicking the cell pops up the description in a small
/// dialog anchored under the label.
component LabelCell inherits Rectangle {
    in property <string> label;
    in property <string> description: "";

    // Wide enough for ~95% of ARK SA parameter names without truncation.
    // The longest realistic key is ~45 chars (e.g.
    // "BabyCuddleLoseImprintQualitySpeedMultiplier"); a touch wider than
    // strictly needed so labels with the trailing "(int)" / "(string)"
    // hint don't wrap.
    width: 340px;
    background: ta.has-hover && root.description != ""
        ? AppTheme.accent-soft
        : transparent;
    border-radius: 3px;

    HorizontalBox {
        padding: 4px;
        spacing: 4px;
        Text {
            text: root.label;
            vertical-alignment: center;
            color: Palette.foreground;
            horizontal-stretch: 1;
            // Wrap rather than elide so long names stay fully readable
            // even when they overflow the cell width.
            wrap: word-wrap;
        }
        // A subtle "ⓘ" affordance only when a description exists.
        if root.description != "": Text {
            text: "ⓘ";
            color: AppTheme.accent;
            vertical-alignment: center;
            font-size: 13px;
        }
    }

    ta := TouchArea {
        enabled: root.description != "";
        mouse-cursor: root.description != "" ? MouseCursor.pointer : MouseCursor.default;
        clicked => { popup.show(); }
    }

    popup := PopupWindow {
        x: 0;
        // Position the popup *above* the label cell. We can't reference
        // `popup_body.height` (PopupWindow → child cycle resolves it to 0)
        // so we use a fixed offset sized for the typical body height
        // (~100–140 px on a 360 px-wide bilingual description).
        //
        // -50 px (per user request). The popup ends up overlapping the
        // clicked label and extending downward over the next rows, but
        // that is the position they asked for.
        y: -50px;
        close-policy: close-on-click-outside;
        popup_body := Rectangle {
            background: Palette.alternate-background;
            border-color: AppTheme.border;
            border-width: 1px;
            border-radius: 6px;
            drop-shadow-blur: 8px;
            drop-shadow-color: #00000080;
            width: 360px;
            VerticalLayout {
                padding: 10px;
                spacing: 4px;
                Text {
                    text: root.label;
                    color: AppTheme.accent;
                    font-weight: 700;
                    wrap: word-wrap;
                }
                Text {
                    text: root.description;
                    color: Palette.foreground;
                    wrap: word-wrap;
                }
            }
        }
    }
}

/// One labelled float row used inside the World Settings categories.
///
/// `label` is the literal ARK key (always English — that's what the server
/// reads). `description` is a short bilingual hint shown as a popup when the
/// user clicks the label. Callers set it via a
/// `description: root.lang-ja ? "..." : "..."` ternary so the dialog can
/// switch language without a restart.
component WorldFloatRow inherits HorizontalBox {
    in property <string> label;
    in property <string> description: "";
    in-out property <string> value;
    spacing: 8px;
    padding: 0;

    LabelCell {
        label: root.label;
        description: root.description;
    }
    LineEdit {
        text <=> root.value;
        // Fixed width keeps the input next to the label instead of
        // stretching all the way to the right edge of the window.
        width: 180px;
        input-type: text;
    }
    // Spacer so the row's right side has empty space rather than
    // pulling the LineEdit to the far edge.
    Rectangle { horizontal-stretch: 1; }
}

component WorldBoolRow inherits HorizontalBox {
    in property <string> label;
    in property <string> description: "";
    in-out property <bool> value;
    spacing: 8px;
    padding: 0;

    LabelCell {
        label: root.label;
        description: root.description;
    }
    CheckBox {
        checked <=> root.value;
    }
    Rectangle { horizontal-stretch: 1; }
}

/// Sidebar entry for the World Settings dialog. Highlights itself in the
/// project's turquoise accent when the `index` matches `current-index`
/// and fires `clicked` so the parent can swap the active category.
component CategoryButton inherits Rectangle {
    in property <string> label;
    in property <int> index;
    in property <int> current-index;
    callback clicked;

    height: 30px;
    border-radius: 4px;
    background: root.index == root.current-index
        ? AppTheme.accent
        : (touch.has-hover ? AppTheme.accent-soft : transparent);

    HorizontalBox {
        padding-left: 12px;
        padding-right: 8px;
        Text {
            text: root.label;
            color: root.index == root.current-index
                ? AppTheme.on-accent
                : Palette.foreground;
            font-weight: root.index == root.current-index ? 700 : 400;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component WorldSettingsWindow inherits Window {
    title: root.labels.world_window_title;
    // Roughly: 170 (sidebar) + 340 (LabelCell) + 180 (LineEdit) +
    // padding/margins ≈ 760 px just for the form. Bumped from 720 to
    // 980 so the input column is fully visible at the default opening
    // size (rather than relying on the user resizing or scrolling).
    preferred-width: 980px;
    preferred-height: 700px;
    min-width: 700px;
    min-height: 480px;

    in property <UiLabels> labels;
    in property <string> validation-error: "";
    in property <bool> busy: false;
    /// Current language is Japanese? Drives the per-row bilingual description
    /// text. Set from Rust based on AppSettings.language() so descriptions
    /// honour the same setting as the rest of the GUI.
    in property <bool> lang-ja: false;
    /// Index of the active category (sidebar selection). 0 = Rates,
    /// 1 = Day cycle, …, 16 = Launch flags. The conditional blocks in the
    /// content pane render based on this.
    in-out property <int> current-category: 0;

    // Field properties — strings for floats so we can validate / format on
    // the Rust side, bools for booleans. Each is grouped by tab.

    // Rates
    in-out property <string> f_xp_multiplier: "1.0";
    in-out property <string> f_harvest_amount_multiplier: "1.0";
    in-out property <string> f_harvest_health_multiplier: "1.0";
    in-out property <string> f_resources_respawn_period_multiplier: "1.0";
    in-out property <string> f_taming_speed_multiplier: "1.0";
    in-out property <string> f_mating_interval_multiplier: "1.0";
    in-out property <string> f_egg_hatch_speed_multiplier: "1.0";
    in-out property <string> f_baby_mature_speed_multiplier: "1.0";

    // Day cycle
    in-out property <string> f_day_cycle_speed_scale: "1.0";
    in-out property <string> f_day_time_speed_scale: "1.0";
    in-out property <string> f_night_time_speed_scale: "1.0";

    // Player
    in-out property <string> f_player_food: "1.0";
    in-out property <string> f_player_water: "1.0";
    in-out property <string> f_player_stamina: "1.0";
    in-out property <string> f_player_health_recovery: "1.0";
    in-out property <string> f_player_damage: "1.0";
    in-out property <string> f_player_resistance: "1.0";
    in-out property <string> f_player_harvesting: "1.0";

    // Tamed dino
    in-out property <string> f_dino_food: "1.0";
    in-out property <string> f_dino_stamina: "1.0";
    in-out property <string> f_dino_health_recovery: "1.0";
    in-out property <string> f_tamed_damage: "1.0";
    in-out property <string> f_tamed_resistance: "1.0";

    // Wild dino
    in-out property <string> f_wild_food: "1.0";
    in-out property <string> f_wild_stamina: "1.0";
    in-out property <string> f_wild_torpor: "1.0";
    in-out property <string> f_dino_count: "1.0";

    // Difficulty / structure
    in-out property <string> f_difficulty_offset: "0.2";
    in-out property <string> f_override_official_difficulty: "5.0";
    in-out property <string> f_structure_damage: "1.0";
    in-out property <string> f_structure_resistance: "1.0";
    in-out property <string> f_structure_repair_cooldown: "180.0";
    in-out property <bool> b_disable_imprint_dino_buff: false;
    in-out property <bool> b_allow_anyone_baby_imprint: false;

    // Phase 8b — PvE/PvP toggles
    in-out property <bool> b_server_pve: false;
    in-out property <bool> b_allow_flyer_carry_pve: false;
    in-out property <bool> b_enable_cryo_sickness_pve: false;
    in-out property <bool> b_disable_structure_decay_pve: false;

    // Phase 8b — Operations basics
    in-out property <string> f_max_tamed_dinos: "5000.0";
    in-out property <string> f_kick_idle_players_period: "3600.0";
    in-out property <string> f_auto_save_period_minutes: "15.0";
    in-out property <string> f_the_max_structures_in_range: "10500";

    // Phase 8c — Breeding / Imprint
    in-out property <string> f_mating_speed_multiplier: "1.0";
    in-out property <string> f_lay_egg_interval_multiplier: "1.0";
    in-out property <string> f_passive_tame_interval_multiplier: "1.0";
    in-out property <string> f_baby_food_consumption_speed_multiplier: "1.0";
    in-out property <string> f_baby_imprint_amount_multiplier: "1.0";
    in-out property <string> f_baby_imprinting_stat_scale_multiplier: "1.0";
    in-out property <string> f_baby_cuddle_interval_multiplier: "1.0";
    in-out property <string> f_baby_cuddle_grace_period_multiplier: "1.0";
    in-out property <string> f_baby_cuddle_lose_imprint_quality_speed_multiplier: "1.0";
    in-out property <bool> b_disable_dino_breeding: false;
    in-out property <bool> b_disable_dino_taming: false;

    // Phase 8d — Loot / Spoilage
    in-out property <string> f_supply_crate_loot_quality_multiplier: "1.0";
    in-out property <string> f_fishing_loot_quality_multiplier: "1.0";
    in-out property <string> f_crop_decay_speed_multiplier: "1.0";
    in-out property <string> f_crop_growth_speed_multiplier: "1.0";
    in-out property <bool> b_disable_loot_crates: false;
    in-out property <string> f_limit_non_player_dropped_items_count: "0";
    in-out property <string> f_limit_non_player_dropped_items_range: "0";
    in-out property <string> f_global_item_decomposition_time_multiplier: "1.0";
    in-out property <string> f_global_spoiling_time_multiplier: "1.0";
    in-out property <string> f_global_corpse_decomposition_time_multiplier: "1.0";
    in-out property <string> f_use_corpse_life_span_multiplier: "1.0";
    in-out property <bool> b_use_corpse_locator: true;
    in-out property <string> f_poop_interval_multiplier: "1.0";
    in-out property <string> f_fuel_consumption_interval_multiplier: "1.0";
    in-out property <string> f_max_fall_speed_multiplier: "1.0";

    // Phase 8e — Stat arrays (PerLevelStatsMultiplier_* + PlayerBaseStatMultipliers)
    // Indices: 0=Health 1=Stamina 2=Torpidity 3=Oxygen 4=Food 5=Water
    //          6=Temperature 7=Weight 8=MeleeDamage 9=Speed 10=Fortitude 11=CraftingSpeed
    in-out property <string> f_pls_player_0: "1.0";
    in-out property <string> f_pls_player_1: "1.0";
    in-out property <string> f_pls_player_2: "1.0";
    in-out property <string> f_pls_player_3: "1.0";
    in-out property <string> f_pls_player_4: "1.0";
    in-out property <string> f_pls_player_5: "1.0";
    in-out property <string> f_pls_player_6: "1.0";
    in-out property <string> f_pls_player_7: "1.0";
    in-out property <string> f_pls_player_8: "1.0";
    in-out property <string> f_pls_player_9: "1.0";
    in-out property <string> f_pls_player_10: "1.0";
    in-out property <string> f_pls_player_11: "1.0";
    in-out property <string> f_pls_tamed_0: "1.0";
    in-out property <string> f_pls_tamed_1: "1.0";
    in-out property <string> f_pls_tamed_2: "1.0";
    in-out property <string> f_pls_tamed_3: "1.0";
    in-out property <string> f_pls_tamed_4: "1.0";
    in-out property <string> f_pls_tamed_5: "1.0";
    in-out property <string> f_pls_tamed_6: "1.0";
    in-out property <string> f_pls_tamed_7: "1.0";
    in-out property <string> f_pls_tamed_8: "1.0";
    in-out property <string> f_pls_tamed_9: "1.0";
    in-out property <string> f_pls_tamed_10: "1.0";
    in-out property <string> f_pls_tamed_11: "1.0";
    in-out property <string> f_pls_tamed_add_0: "1.0";
    in-out property <string> f_pls_tamed_add_1: "1.0";
    in-out property <string> f_pls_tamed_add_2: "1.0";
    in-out property <string> f_pls_tamed_add_3: "1.0";
    in-out property <string> f_pls_tamed_add_4: "1.0";
    in-out property <string> f_pls_tamed_add_5: "1.0";
    in-out property <string> f_pls_tamed_add_6: "1.0";
    in-out property <string> f_pls_tamed_add_7: "1.0";
    in-out property <string> f_pls_tamed_add_8: "1.0";
    in-out property <string> f_pls_tamed_add_9: "1.0";
    in-out property <string> f_pls_tamed_add_10: "1.0";
    in-out property <string> f_pls_tamed_add_11: "1.0";
    in-out property <string> f_pls_tamed_affinity_0: "1.0";
    in-out property <string> f_pls_tamed_affinity_1: "1.0";
    in-out property <string> f_pls_tamed_affinity_2: "1.0";
    in-out property <string> f_pls_tamed_affinity_3: "1.0";
    in-out property <string> f_pls_tamed_affinity_4: "1.0";
    in-out property <string> f_pls_tamed_affinity_5: "1.0";
    in-out property <string> f_pls_tamed_affinity_6: "1.0";
    in-out property <string> f_pls_tamed_affinity_7: "1.0";
    in-out property <string> f_pls_tamed_affinity_8: "1.0";
    in-out property <string> f_pls_tamed_affinity_9: "1.0";
    in-out property <string> f_pls_tamed_affinity_10: "1.0";
    in-out property <string> f_pls_tamed_affinity_11: "1.0";
    in-out property <string> f_pls_wild_0: "1.0";
    in-out property <string> f_pls_wild_1: "1.0";
    in-out property <string> f_pls_wild_2: "1.0";
    in-out property <string> f_pls_wild_3: "1.0";
    in-out property <string> f_pls_wild_4: "1.0";
    in-out property <string> f_pls_wild_5: "1.0";
    in-out property <string> f_pls_wild_6: "1.0";
    in-out property <string> f_pls_wild_7: "1.0";
    in-out property <string> f_pls_wild_8: "1.0";
    in-out property <string> f_pls_wild_9: "1.0";
    in-out property <string> f_pls_wild_10: "1.0";
    in-out property <string> f_pls_wild_11: "1.0";
    in-out property <string> f_pls_base_0: "1.0";
    in-out property <string> f_pls_base_1: "1.0";
    in-out property <string> f_pls_base_2: "1.0";
    in-out property <string> f_pls_base_3: "1.0";
    in-out property <string> f_pls_base_4: "1.0";
    in-out property <string> f_pls_base_5: "1.0";
    in-out property <string> f_pls_base_6: "1.0";
    in-out property <string> f_pls_base_7: "1.0";
    in-out property <string> f_pls_base_8: "1.0";
    in-out property <string> f_pls_base_9: "1.0";
    in-out property <string> f_pls_base_10: "1.0";
    in-out property <string> f_pls_base_11: "1.0";

    // Phase 8f — Combat / Structures
    in-out property <string> f_dino_harvesting_damage_multiplier: "3.2";
    in-out property <string> f_dino_turret_damage_multiplier: "1.0";
    in-out property <bool> b_allow_speed_leveling: true;
    in-out property <bool> b_allow_flyer_speed_leveling: false;
    in-out property <bool> b_disable_friendly_fire: false;
    in-out property <bool> b_pve_disable_friendly_fire: false;
    in-out property <bool> b_allow_unlimited_respecs: false;
    in-out property <bool> b_hard_limit_turrets_in_range: false;
    in-out property <bool> b_limit_turrets_in_range: true;
    in-out property <string> f_limit_turrets_num: "100";
    in-out property <string> f_limit_turrets_range: "10000";
    in-out property <string> f_structure_prevent_resource_radius_multiplier: "1.0";
    in-out property <string> f_per_platform_max_structures_multiplier: "1.0";
    in-out property <bool> b_always_allow_structure_pickup: false;
    in-out property <string> f_structure_pickup_time_after_placement: "30.0";
    in-out property <string> f_structure_pickup_hold_duration: "0.5";
    in-out property <string> f_max_platform_saddle_structure_limit: "75";
    in-out property <bool> b_enable_cryopod_nerf: false;
    in-out property <string> f_cryopod_nerf_damage_mult: "0.01";
    in-out property <string> f_cryopod_nerf_duration: "0.0";
    in-out property <bool> b_allow_cryo_fridge_on_saddle: false;
    in-out property <bool> b_disable_cryopod_fridge_requirement: false;

    // Phase 8g — XP gain breakdown
    in-out property <string> f_generic_xp_multiplier: "1.0";
    in-out property <string> f_harvest_xp_multiplier: "1.0";
    in-out property <string> f_kill_xp_multiplier: "1.0";
    in-out property <string> f_craft_xp_multiplier: "1.0";
    in-out property <string> f_special_xp_multiplier: "1.0";
    in-out property <string> f_explorer_note_xp_multiplier: "1.0";
    in-out property <string> f_boss_kill_xp_multiplier: "1.0";
    in-out property <string> f_cave_kill_xp_multiplier: "1.0";
    in-out property <string> f_wild_kill_xp_multiplier: "1.0";
    in-out property <string> f_tamed_kill_xp_multiplier: "1.0";
    in-out property <string> f_unclaimed_kill_xp_multiplier: "1.0";
    in-out property <string> f_alpha_kill_xp_multiplier: "1.0";
    in-out property <string> f_override_max_experience_points_player: "0";
    in-out property <string> f_override_max_experience_points_dino: "0";

    // Phase 8h — Cosmetic / Chat
    in-out property <bool> b_global_voice_chat: false;
    in-out property <bool> b_proximity_chat: false;
    in-out property <bool> b_dont_always_notify_player_joined: false;
    in-out property <bool> b_always_notify_player_left: false;
    in-out property <bool> b_admin_logging: false;
    in-out property <bool> b_allow_hide_damage_source_from_logs: false;
    in-out property <bool> b_show_floating_damage_text: false;
    in-out property <bool> b_show_map_player_location: true;
    in-out property <bool> b_server_crosshair: true;
    in-out property <bool> b_server_force_no_hud: false;
    in-out property <bool> b_allow_third_person_player: true;
    in-out property <bool> b_allow_hit_markers: true;
    in-out property <bool> b_disable_pve_gamma: false;
    in-out property <bool> b_enable_pvp_gamma: false;

    // Phase 8i — Cluster / Lists
    in-out property <string> f_server_password: "";
    in-out property <string> f_ban_list_url: "";
    in-out property <string> f_admin_list_url: "";
    in-out property <string> f_bad_word_list_url: "";
    in-out property <string> f_bad_word_white_list_url: "";
    in-out property <string> f_custom_live_tuning_url: "";
    in-out property <bool> b_no_tribute_downloads: false;
    in-out property <bool> b_prevent_download_dinos: false;
    in-out property <bool> b_prevent_download_items: false;
    in-out property <bool> b_prevent_download_survivors: false;
    in-out property <bool> b_prevent_upload_dinos: false;
    in-out property <bool> b_prevent_upload_items: false;
    in-out property <bool> b_prevent_upload_survivors: false;
    in-out property <bool> b_cross_ark_allow_foreign_dino_downloads: false;
    in-out property <bool> b_prevent_tribe_alliances: false;
    in-out property <string> f_max_number_of_players_in_tribe: "0";

    // Phase 8j — Stat clamps / Blueprint caps
    in-out property <string> f_max_blueprint_dino_level: "0";
    in-out property <string> f_max_blueprint_dino_quality: "0";
    in-out property <string> f_max_blueprint_item_quality: "0";
    in-out property <string> f_max_blueprint_scout_quality: "0";
    in-out property <string> f_max_hexagons_per_character: "2000000000";
    in-out property <bool> b_clamp_item_spoiling_times: false;
    in-out property <bool> b_clamp_item_stats: false;
    in-out property <bool> b_clamp_resource_harvest_damage: false;
    in-out property <string> f_implant_suicide_cd: "28800";
    in-out property <string> f_server_auto_force_respawn_wild_dinos_interval: "0.0";
    in-out property <string> f_destroy_tames_over_level_clamp: "0";

    // Phase 8L — extra GameUserSettings.ini knobs (PvP/decay,
    // multipliers/物量, behaviour/safety/disease)
    in-out property <bool> b_fast_decay_unsnapped_core_structures: false;
    in-out property <bool> b_override_structure_platform_prevention: false;
    in-out property <bool> b_prevent_offline_pvp: false;
    in-out property <string> f_prevent_offline_pvp_interval: "0.0";
    in-out property <bool> b_pvp_dino_decay: false;
    in-out property <bool> b_pvp_structure_decay: false;
    in-out property <string> f_pve_dino_decay_period_multiplier: "1.0";
    in-out property <bool> b_only_auto_destroy_core_structures: false;
    in-out property <bool> b_auto_destroy_decayed_dinos: false;
    in-out property <bool> b_tribe_log_destroyed_enemy_structures: false;
    in-out property <bool> b_pve_allow_structures_at_supply_drops: false;
    in-out property <string> f_oxygen_swim_speed_stat_multiplier: "1.0";
    in-out property <string> f_tribe_name_change_cooldown: "15.0";
    in-out property <string> f_platform_saddle_build_area_bounds_multiplier: "1.0";
    in-out property <string> f_raid_dino_character_food_drain_multiplier: "1.0";
    in-out property <string> f_item_stack_size_multiplier: "1.0";
    in-out property <string> f_start_time_hour: "-1.0";
    in-out property <string> f_rcon_server_game_log_buffer: "600";
    in-out property <bool> b_allow_raid_dino_feeding: true;
    in-out property <bool> b_enable_extra_structure_prevention_volumes: false;
    in-out property <bool> b_prevent_spawn_animations: false;
    in-out property <bool> b_prevent_diseases: false;
    in-out property <bool> b_non_permanent_diseases: false;
    in-out property <bool> b_use_optimized_harvesting_health: false;
    in-out property <bool> b_allow_multiple_attached_c4: false;
    in-out property <bool> b_allow_flying_stamina_recovery: false;
    in-out property <bool> b_allow_crate_spawns_on_top_of_structures: false;

    // Phase 8k — Launch flags (saved into Profile MM_Command_Val)
    in-out property <string> f_launch_flags: "";
    in property <string> f_launch_flags_reference: "";

    callback import-clicked();
    callback reset-clicked();
    callback save-clicked();
    callback cancel-clicked();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        Text {
            text: root.labels.world_hint;
            wrap: word-wrap;
        }

        HorizontalBox {
            alignment: start;
            spacing: 8px;
            Button {
                text: root.labels.world_btn_import;
                enabled: !root.busy;
                clicked => { root.import-clicked(); }
            }
            Button {
                text: root.labels.world_btn_reset;
                enabled: !root.busy;
                clicked => { root.reset-clicked(); }
            }
        }

        HorizontalBox {
            vertical-stretch: 1;
            spacing: 0;
            padding: 0;

            // Left: category sidebar
            Rectangle {
                // Just wide enough for the longest localized category name
                // ("Difficulty / structure" / "難易度・建造物") with a bit of
                // breathing room. Was 200 px previously.
                width: 170px;
                background: Palette.alternate-background;
                VerticalLayout {
                    spacing: 0;
                    // Sidebar header — same turquoise styling as the
                    // right-pane "Parameter / Value" headers so the user
                    // can tell at a glance that this column is the
                    // category picker.
                    Rectangle {
                        height: 38px;
                        background: AppTheme.header-bg;
                        HorizontalBox {
                            padding-left: 12px;
                            padding-right: 12px;
                            Rectangle {
                                height: 22px;
                                background: AppTheme.header-bg;
                                vertical-stretch: 0;
                                Text {
                                    text: root.labels.world_col_category;
                                    color: AppTheme.accent;
                                    font-weight: 700;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    x: 0;
                                }
                            }
                        }
                    }
                ScrollView {
                    VerticalBox {
                        padding: 4px;
                        spacing: 1px;
                        CategoryButton { index: 0;  current-index: root.current-category; label: root.labels.world_tab_rates;       clicked => { root.current-category = 0;  } }
                        CategoryButton { index: 1;  current-index: root.current-category; label: root.labels.world_tab_day;         clicked => { root.current-category = 1;  } }
                        CategoryButton { index: 2;  current-index: root.current-category; label: root.labels.world_tab_player;      clicked => { root.current-category = 2;  } }
                        CategoryButton { index: 3;  current-index: root.current-category; label: root.labels.world_tab_tamed;       clicked => { root.current-category = 3;  } }
                        CategoryButton { index: 4;  current-index: root.current-category; label: root.labels.world_tab_wild;        clicked => { root.current-category = 4;  } }
                        CategoryButton { index: 5;  current-index: root.current-category; label: root.labels.world_tab_difficulty;  clicked => { root.current-category = 5;  } }
                        CategoryButton { index: 6;  current-index: root.current-category; label: root.labels.world_tab_pvp;         clicked => { root.current-category = 6;  } }
                        CategoryButton { index: 7;  current-index: root.current-category; label: root.labels.world_tab_ops;         clicked => { root.current-category = 7;  } }
                        CategoryButton { index: 8;  current-index: root.current-category; label: root.labels.world_tab_breeding;    clicked => { root.current-category = 8;  } }
                        CategoryButton { index: 9;  current-index: root.current-category; label: root.labels.world_tab_loot;        clicked => { root.current-category = 9;  } }
                        CategoryButton { index: 10; current-index: root.current-category; label: root.labels.world_tab_stats;       clicked => { root.current-category = 10; } }
                        CategoryButton { index: 11; current-index: root.current-category; label: root.labels.world_tab_combat;      clicked => { root.current-category = 11; } }
                        CategoryButton { index: 12; current-index: root.current-category; label: root.labels.world_tab_xp;          clicked => { root.current-category = 12; } }
                        CategoryButton { index: 13; current-index: root.current-category; label: root.labels.world_tab_chat;        clicked => { root.current-category = 13; } }
                        CategoryButton { index: 14; current-index: root.current-category; label: root.labels.world_tab_cluster;     clicked => { root.current-category = 14; } }
                        CategoryButton { index: 15; current-index: root.current-category; label: root.labels.world_tab_clamps;      clicked => { root.current-category = 15; } }
                        CategoryButton { index: 16; current-index: root.current-category; label: root.labels.world_tab_flags;       clicked => { root.current-category = 16; } }
                    }
                }
                }   // end sidebar VerticalLayout (header + ScrollView)
            }

            // Right: content pane (only the currently-selected category renders)
            VerticalBox {
                horizontal-stretch: 1;
                padding: 0;
                spacing: 0;

            // Column headers — same widths as the LabelCell + LineEdit
            // pair below so each column header lines up over its values.
            // Hidden for the Launch flags category (16) which has a
            // different (free-form text) layout.
            if root.current-category != 16: HorizontalBox {
                spacing: 8px;
                padding: 8px;
                Rectangle {
                    width: 340px;
                    height: 22px;
                    background: AppTheme.header-bg;
                    border-radius: 3px;
                    Text {
                        text: root.labels.world_col_param;
                        x: 8px;
                        color: AppTheme.accent;
                        font-weight: 700;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
                Rectangle {
                    width: 180px;
                    height: 22px;
                    background: AppTheme.header-bg;
                    border-radius: 3px;
                    Text {
                        text: root.labels.world_col_value;
                        x: 8px;
                        color: AppTheme.accent;
                        font-weight: 700;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
            }

            if root.current-category == 0: Rectangle {
                background: Palette.background;
                ScrollView {
                    VerticalBox {
                        padding: 8px;
                        spacing: 4px;
                        WorldFloatRow {
                            label: "XPMultiplier";
                            description: root.lang-ja
                                ? "全 XP 獲得倍率（1.0 が標準）。"
                                : "Global multiplier on all XP gain (1.0 = vanilla).";
                            value <=> root.f_xp_multiplier;
                        }
                        WorldFloatRow {
                            label: "HarvestAmountMultiplier";
                            description: root.lang-ja
                                ? "採取 1 回あたりの取得量倍率。"
                                : "Multiplier on resource yield per harvest.";
                            value <=> root.f_harvest_amount_multiplier;
                        }
                        WorldFloatRow {
                            label: "HarvestHealthMultiplier";
                            description: root.lang-ja
                                ? "資源ノードの体力倍率（高いほど多く叩ける）。"
                                : "Resource node HP — higher = more hits per node.";
                            value <=> root.f_harvest_health_multiplier;
                        }
                        WorldFloatRow {
                            label: "ResourcesRespawnPeriodMultiplier";
                            description: root.lang-ja
                                ? "資源リスポーン間隔倍率（小さいほど早く再生）。"
                                : "Time between resource respawns (lower = faster).";
                            value <=> root.f_resources_respawn_period_multiplier;
                        }
                        WorldFloatRow {
                            label: "TamingSpeedMultiplier";
                            description: root.lang-ja
                                ? "テイム速度倍率。"
                                : "Speed of all taming.";
                            value <=> root.f_taming_speed_multiplier;
                        }
                        WorldFloatRow {
                            label: "MatingIntervalMultiplier";
                            description: root.lang-ja
                                ? "連続交配の間隔倍率（小さいほど早く再交配可能）。"
                                : "Time between successive matings (lower = faster).";
                            value <=> root.f_mating_interval_multiplier;
                        }
                        WorldFloatRow {
                            label: "EggHatchSpeedMultiplier";
                            description: root.lang-ja
                                ? "卵の孵化速度倍率。"
                                : "Egg incubation speed.";
                            value <=> root.f_egg_hatch_speed_multiplier;
                        }
                        WorldFloatRow {
                            label: "BabyMatureSpeedMultiplier";
                            description: root.lang-ja
                                ? "赤ちゃんの成長速度倍率。"
                                : "Baby growth speed.";
                            value <=> root.f_baby_mature_speed_multiplier;
                        }
                    }
                }
            }

            if root.current-category == 1: Rectangle {
                background: Palette.background;
                ScrollView {
                    VerticalBox {
                        padding: 8px;
                        spacing: 4px;
                        WorldFloatRow {
                            label: "DayCycleSpeedScale";
                            description: root.lang-ja
                                ? "昼夜サイクル全体の速度。"
                                : "Overall day/night cycle speed.";
                            value <=> root.f_day_cycle_speed_scale;
                        }
                        WorldFloatRow {
                            label: "DayTimeSpeedScale";
                            description: root.lang-ja
                                ? "昼の長さの倍率。"
                                : "Day length scale.";
                            value <=> root.f_day_time_speed_scale;
                        }
                        WorldFloatRow {
