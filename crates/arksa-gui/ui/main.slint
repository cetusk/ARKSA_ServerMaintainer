                            value <=> root.b_show_map_player_location;
                        }
                        WorldBoolRow {
                            label: "ServerCrosshair";
                            description: root.lang-ja
                                ? "クロスヘアを表示。"
                                : "Force crosshair on.";
                            value <=> root.b_server_crosshair;
                        }
                        WorldBoolRow {
                            label: "ServerForceNoHUD";
                            description: root.lang-ja
                                ? "HUD を完全に非表示。"
                                : "Hide HUD entirely.";
                            value <=> root.b_server_force_no_hud;
                        }
                        WorldBoolRow {
                            label: "AllowThirdPersonPlayer";
                            description: root.lang-ja
                                ? "三人称視点を許可。"
                                : "Allow third-person camera.";
                            value <=> root.b_allow_third_person_player;
                        }
                        WorldBoolRow {
                            label: "AllowHitMarkers";
                            description: root.lang-ja
                                ? "ヒットマーカーを表示。"
                                : "Show hit markers.";
                            value <=> root.b_allow_hit_markers;
                        }
                        WorldBoolRow {
                            label: "DisablePvEGamma";
                            description: root.lang-ja
                                ? "PvE でガンマ調整を無効化。"
                                : "Block gamma override in PvE.";
                            value <=> root.b_disable_pve_gamma;
                        }
                        WorldBoolRow {
                            label: "EnablePvPGamma";
                            description: root.lang-ja
                                ? "PvP でガンマ調整を許可。"
                                : "Allow gamma override in PvP.";
                            value <=> root.b_enable_pvp_gamma;
                        }
                        WorldBoolRow {
                            label: "PreventSpawnAnimations";
                            description: root.lang-ja
                                ? "恐竜スポーンアニメをスキップ (処理軽減)。"
                                : "Skip dino spawn animations (perf).";
                            value <=> root.b_prevent_spawn_animations;
                        }
                        WorldBoolRow {
                            label: "TribeLogDestroyedEnemyStructures";
                            description: root.lang-ja
                                ? "敵建造物の破壊を部族ログに記録。"
                                : "Log enemy structure destruction in tribe log.";
                            value <=> root.b_tribe_log_destroyed_enemy_structures;
                        }
                        WorldFloatRow {
                            label: "RCONServerGameLogBuffer (int)";
                            description: root.lang-ja
                                ? "RCON 経由で取得可能なゲームログ行数上限。"
                                : "Max game-log lines RCON exposes in one query.";
                            value <=> root.f_rcon_server_game_log_buffer;
                        }
                        WorldBoolRow {
                            label: "UseOptimizedHarvestingHealth";
                            description: root.lang-ja
                                ? "採取時の体力計算を最適化版に切替。"
                                : "Use the optimized harvesting health calculations.";
                            value <=> root.b_use_optimized_harvesting_health;
                        }
                    }
                }
            }

            if root.current-category == 14: Rectangle {
                background: Palette.background;
                ScrollView {
                    VerticalBox {
                        padding: 8px;
                        spacing: 6px;
                        GroupBox {
                            title: "Passwords / URLs (GameUserSettings.ini)";
                            VerticalBox {
                                padding: 4px;
                                spacing: 2px;
                                WorldFloatRow {
                                    label: "ServerPassword (string)";
                                    description: root.lang-ja
                                        ? "参加パスワード（空欄で誰でも参加可）。"
                                        : "Join password (blank = open server).";
                                    value <=> root.f_server_password;
                                }
                                WorldFloatRow {
                                    label: "BanListURL (string)";
                                    description: root.lang-ja
                                        ? "リモート BAN リスト URL。"
                                        : "URL to remote ban list.";
                                    value <=> root.f_ban_list_url;
                                }
                                WorldFloatRow {
                                    label: "AdminListURL (string)";
                                    description: root.lang-ja
                                        ? "リモート管理者リスト URL。"
                                        : "URL to remote admin list.";
                                    value <=> root.f_admin_list_url;
                                }
                                WorldFloatRow {
                                    label: "BadWordListURL (string)";
                                    description: root.lang-ja
                                        ? "チャット禁止ワードリスト URL。"
                                        : "URL to chat filter bad-word list.";
                                    value <=> root.f_bad_word_list_url;
                                }
                                WorldFloatRow {
                                    label: "BadWordWhiteListURL (string)";
                                    description: root.lang-ja
                                        ? "フィルタ例外ワードリスト URL。"
                                        : "URL to filter exception list.";
                                    value <=> root.f_bad_word_white_list_url;
                                }
                                WorldFloatRow {
                                    label: "CustomLiveTuningUrl (string)";
                                    description: root.lang-ja
                                        ? "ライブ設定配信 URL。"
                                        : "Live config feed URL.";
                                    value <=> root.f_custom_live_tuning_url;
                                }
                            }
                        }
                        GroupBox {
                            title: "Cross-ARK transfer (GameUserSettings.ini)";
                            VerticalBox {
                                padding: 4px;
                                spacing: 2px;
                                WorldBoolRow {
                                    label: "noTributeDownloads";
                                    description: root.lang-ja
                                        ? "クロスサーバー DL を全面禁止。"
                                        : "Disable cross-server downloads entirely.";
                                    value <=> root.b_no_tribute_downloads;
                                }
                                WorldBoolRow {
                                    label: "PreventDownloadDinos";
                                    description: root.lang-ja
                                        ? "恐竜の DL を禁止。"
                                        : "Block dino downloads.";
                                    value <=> root.b_prevent_download_dinos;
                                }
                                WorldBoolRow {
                                    label: "PreventDownloadItems";
                                    description: root.lang-ja
                                        ? "アイテムの DL を禁止。"
                                        : "Block item downloads.";
                                    value <=> root.b_prevent_download_items;
                                }
                                WorldBoolRow {
                                    label: "PreventDownloadSurvivors";
                                    description: root.lang-ja
                                        ? "サバイバー本体の DL を禁止。"
                                        : "Block survivor downloads.";
                                    value <=> root.b_prevent_download_survivors;
                                }
                                WorldBoolRow {
                                    label: "PreventUploadDinos";
                                    description: root.lang-ja
                                        ? "恐竜のアップロードを禁止。"
                                        : "Block dino uploads.";
                                    value <=> root.b_prevent_upload_dinos;
                                }
                                WorldBoolRow {
                                    label: "PreventUploadItems";
                                    description: root.lang-ja
                                        ? "アイテムのアップロードを禁止。"
                                        : "Block item uploads.";
                                    value <=> root.b_prevent_upload_items;
                                }
                                WorldBoolRow {
                                    label: "PreventUploadSurvivors";
                                    description: root.lang-ja
                                        ? "サバイバーのアップロードを禁止。"
                                        : "Block survivor uploads.";
                                    value <=> root.b_prevent_upload_survivors;
                                }
                                WorldBoolRow {
                                    label: "CrossARKAllowForeignDinoDownloads";
                                    description: root.lang-ja
                                        ? "他クラスタからの恐竜 DL を許可。"
                                        : "Allow downloading dinos from other clusters.";
                                    value <=> root.b_cross_ark_allow_foreign_dino_downloads;
                                }
                            }
                        }
                        GroupBox {
                            title: "Tribes (GameUserSettings.ini)";
                            VerticalBox {
                                padding: 4px;
                                spacing: 2px;
                                WorldBoolRow {
                                    label: "PreventTribeAlliances";
                                    description: root.lang-ja
                                        ? "部族同盟を禁止。"
                                        : "Disable tribe alliances.";
                                    value <=> root.b_prevent_tribe_alliances;
                                }
                                WorldFloatRow {
                                    label: "MaxNumberOfPlayersInTribe (int)";
                                    description: root.lang-ja
                                        ? "部族員数上限（0 で無制限）。"
                                        : "Tribe size cap (0 = unlimited).";
                                    value <=> root.f_max_number_of_players_in_tribe;
                                }
                                WorldFloatRow {
                                    label: "TribeNameChangeCooldown";
                                    description: root.lang-ja
                                        ? "部族名変更のクールダウン (分)。"
                                        : "Cooldown (minutes) between tribe name changes.";
                                    value <=> root.f_tribe_name_change_cooldown;
                                }
                            }
                        }
                    }
                }
            }

            if root.current-category == 15: Rectangle {
                background: Palette.background;
                ScrollView {
                    VerticalBox {
                        padding: 8px;
                        spacing: 4px;
                        WorldFloatRow {
                            label: "MaxBlueprintDinoLevel (int, 0=disabled)";
                            description: root.lang-ja
                                ? "恐竜設計図のレベル上限。"
                                : "Cap on dino blueprint level.";
                            value <=> root.f_max_blueprint_dino_level;
                        }
                        WorldFloatRow {
                            label: "MaxBlueprintDinoQuality (int, 0=disabled)";
                            description: root.lang-ja
                                ? "恐竜設計図の品質上限。"
                                : "Cap on dino blueprint quality.";
                            value <=> root.f_max_blueprint_dino_quality;
                        }
                        WorldFloatRow {
                            label: "MaxBlueprintItemQuality (int, 0=disabled)";
                            description: root.lang-ja
                                ? "アイテム設計図の品質上限。"
                                : "Cap on item blueprint quality.";
                            value <=> root.f_max_blueprint_item_quality;
                        }
                        WorldFloatRow {
                            label: "MaxBlueprintScoutQuality (int, 0=disabled)";
                            description: root.lang-ja
                                ? "スカウト設計図の品質上限。"
                                : "Cap on scout blueprint quality.";
                            value <=> root.f_max_blueprint_scout_quality;
                        }
                        WorldFloatRow {
                            label: "MaxHexagonsPerCharacter (int)";
                            description: root.lang-ja
                                ? "キャラ 1 体当たりのヘキサ保有上限。"
                                : "Hexagon hold cap per character.";
                            value <=> root.f_max_hexagons_per_character;
                        }
                        WorldBoolRow {
                            label: "ClampItemSpoilingTimes";
                            description: root.lang-ja
                                ? "アイテム腐敗時間に上限を強制。"
                                : "Clamp item spoil times.";
                            value <=> root.b_clamp_item_spoiling_times;
                        }
                        WorldBoolRow {
                            label: "ClampItemStats";
                            description: root.lang-ja
                                ? "アイテムの内部ステータスに上限を強制。"
                                : "Clamp item stats.";
                            value <=> root.b_clamp_item_stats;
                        }
                        WorldBoolRow {
                            label: "ClampResourceHarvestDamage";
                            description: root.lang-ja
                                ? "採取ダメージに上限を強制（exploit 対策）。"
                                : "Clamp harvest damage to prevent exploits.";
                            value <=> root.b_clamp_resource_harvest_damage;
                        }
                        WorldFloatRow {
                            label: "ImplantSuicideCD (sec)";
                            description: root.lang-ja
                                ? "インプラント自殺のクールダウン（秒）。"
                                : "Cooldown on implant suicide (sec).";
                            value <=> root.f_implant_suicide_cd;
                        }
                        WorldFloatRow {
                            label: "ServerAutoForceRespawnWildDinosInterval";
                            description: root.lang-ja
                                ? "野生恐竜自動再湧出間隔（秒、0 で無効）。"
                                : "Auto wild dino wipe interval (sec, 0 = off).";
                            value <=> root.f_server_auto_force_respawn_wild_dinos_interval;
                        }
                        WorldFloatRow {
                            label: "DestroyTamesOverLevelClamp (Game.ini, int)";
                            description: root.lang-ja
                                ? "この Lv 超過のテイムを自動削除（0 で無効）。"
                                : "Auto-delete tames over this level (0 = off).";
                            value <=> root.f_destroy_tames_over_level_clamp;
                        }
                    }
                }
            }

            if root.current-category == 16: Rectangle {
                background: Palette.background;
                VerticalBox {
                    padding: 8px;
                    spacing: 6px;
                    Text {
                        text: root.lang-ja
                            ? "Profile の MM_Command_Val のうち -flag 部分だけを編集します。各トークンは `-` で始まり空白区切り。URL 部 (map / ports / mods) には触れません。"
                            : "Edits the `-flag` portion of the profile's MM_Command_Val. Each token starts with `-` and is whitespace-separated. The URL portion (map / ports / mods) stays untouched.";
                        wrap: word-wrap;
                    }
                    TextEdit {
                        text <=> root.f_launch_flags;
                        wrap: word-wrap;
                        vertical-stretch: 2;
                    }
                    Text {
                        text: root.lang-ja
                            ? "よく使うフラグの参考リスト (上のフィールドにコピー＆ペースト):"
                            : "Common flags reference (click into the field above and copy/paste):";
                    }
                    ScrollView {
                        vertical-stretch: 1;
                        Text {
                            text: root.f_launch_flags_reference;
                            wrap: word-wrap;
                            font-family: "Consolas, monospace";
                        }
                    }
                }
            }
            }   // end right-pane VerticalBox
        }       // end HorizontalBox sidebar+content

        if root.validation-error != "": Text {
            text: root.validation-error;
            color: #c62828;
            wrap: word-wrap;
        }

        HorizontalBox {
            alignment: end;
            spacing: 8px;
            Button {
                text: root.labels.world_btn_cancel;
                enabled: !root.busy;
                clicked => { root.cancel-clicked(); }
            }
            Button {
                text: root.labels.world_btn_save;
                primary: true;
                enabled: !root.busy;
                clicked => { root.save-clicked(); }
            }
        }
    }
}

// ─── Notification settings dialog ─────────────────────────────────────────

export component NotificationsWindow inherits Window {
    title: root.labels.notifications_window_title;
    preferred-width: 520px;
    preferred-height: 540px;

    in property <UiLabels> labels;
    in property <[string]> language-options: ["Auto (system)", "English", "日本語"];
    in-out property <int> language-index: 0;

    in-out property <string> webhook-url: "";
    in-out property <string> display-name: "";
    in-out property <bool> tray-enabled: true;

    in-out property <bool> ev-server-starting: true;
    in-out property <bool> ev-server-online: false;
    in-out property <bool> ev-server-stopped: true;
    in-out property <bool> ev-crash-detected: false;
    in-out property <bool> ev-asasm-update: false;
    in-out property <bool> ev-server-app-update: false;

    in property <string> validation-error: "";

    callback save-clicked();
    callback cancel-clicked();
    callback test-webhook-clicked();

    VerticalBox {
        padding: 14px;
        spacing: 10px;

        GroupBox {
            title: root.labels.notif_section_discord;
            VerticalBox {
                spacing: 6px;
                HorizontalBox {
                    Text { text: root.labels.notif_webhook_url; vertical-alignment: center; min-width: 130px; }
                    LineEdit {
                        text <=> root.webhook-url;
                        placeholder-text: "https://discord.com/api/webhooks/...";
                        horizontal-stretch: 1;
                    }
                }
                HorizontalBox {
                    Text { text: root.labels.notif_display_name; vertical-alignment: center; min-width: 130px; }
                    LineEdit {
                        text <=> root.display-name;
                        placeholder-text: "ARKSA";
                        horizontal-stretch: 1;
                    }
                    Button {
                        text: root.labels.notif_btn_test;
                        clicked => { root.test-webhook-clicked(); }
                    }
                }
            }
        }

        GroupBox {
            title: root.labels.notif_section_tray;
            VerticalBox {
                spacing: 6px;
                CheckBox {
                    text: root.labels.notif_tray_enabled_text;
                    checked <=> root.tray-enabled;
                }
            }
        }

        GroupBox {
            title: root.labels.notif_section_events;
            VerticalBox {
                spacing: 4px;
                CheckBox { text: "Server starting";              checked <=> root.ev-server-starting; }
                CheckBox { text: "Server online";                checked <=> root.ev-server-online; }
                CheckBox { text: "Server stopped";               checked <=> root.ev-server-stopped; }
                CheckBox { text: "Server crash detected";        checked <=> root.ev-crash-detected; }
                CheckBox { text: "ARKSA tool update available";  checked <=> root.ev-asasm-update; }
                CheckBox { text: "ARK server update available";  checked <=> root.ev-server-app-update; }
            }
        }

        GroupBox {
            title: root.labels.notif_section_language;
            HorizontalBox {
                ComboBox {
                    model: root.language-options;
                    current-index <=> root.language-index;
                    horizontal-stretch: 1;
                }
            }
        }

        if root.validation-error != "": Text {
            text: root.validation-error;
            color: #c62828;
            wrap: word-wrap;
        }

        HorizontalBox {
            alignment: end;
            spacing: 8px;
            Button {
                text: root.labels.notif_btn_cancel;
                clicked => { root.cancel-clicked(); }
            }
            Button {
                text: root.labels.notif_btn_save;
                primary: true;
                clicked => { root.save-clicked(); }
            }
        }
    }
}

// ─── Find window (Mods / Engrams / Items / Dinos) ─────────────────────────

export struct FindEntry {
    name: string,
    class_name: string,
    detail: string,
}

export component FindWindow inherits Window {
    title: root.labels.find_window_title;
    preferred-width: 760px;
    preferred-height: 560px;
    min-width: 540px;
    min-height: 380px;

    in property <UiLabels> labels;
    in property <[string]> categories: ["Mods", "Engrams", "Items", "Dinos"];
    in-out property <int> selected-category: 0;
    in-out property <string> filter-text: "";
    in property <[FindEntry]> entries: [];
    in property <int> total-count: 0;
    in property <int> filtered-count: 0;

    callback category-changed(int);
    callback filter-changed(string);

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            spacing: 8px;
            Text { text: root.labels.find_category; vertical-alignment: center; }
            ComboBox {
                model: root.categories;
                current-index <=> root.selected-category;
                horizontal-stretch: 1;
                selected => { root.category-changed(self.current-index); }
            }
        }

        HorizontalBox {
            spacing: 8px;
            Text { text: root.labels.find_filter; vertical-alignment: center; }
            LineEdit {
                text <=> root.filter-text;
                placeholder-text: root.labels.find_filter_placeholder;
                horizontal-stretch: 1;
                edited => { root.filter-changed(self.text); }
            }
            Text {
                text: root.filtered-count + " / " + root.total-count;
                vertical-alignment: center;
            }
        }

        // Header row
        Rectangle {
            background: #2a2a2a;
            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                Text {
                    text: root.labels.find_col_name;
                    horizontal-stretch: 2;
                    font-weight: 700;
                }
                Text {
                    text: root.labels.find_col_class;
                    horizontal-stretch: 3;
                    font-weight: 700;
                }
                Text {
                    text: root.labels.find_col_info;
                    horizontal-stretch: 1;
                    font-weight: 700;
                }
            }
        }

        ListView {
            vertical-stretch: 1;
            for entry in root.entries: Rectangle {
                height: 24px;
                HorizontalBox {
                    padding-left: 8px;
                    padding-right: 8px;
                    Text {
                        text: entry.name;
                        horizontal-stretch: 2;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                    Text {
                        text: entry.class_name;
                        horizontal-stretch: 3;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                    Text {
                        text: entry.detail;
                        horizontal-stretch: 1;
                        overflow: elide;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

// ─── New Profile dialog ────────────────────────────────────────────────────

export component NewProfileWindow inherits Window {
    title: root.labels.new_profile_window_title;
    preferred-width: 560px;
    preferred-height: 720px;
    min-width: 460px;
    min-height: 560px;

    in property <UiLabels> labels;
    in property <[string]> map-suggestions: [];

    in-out property <string> profile-name: "MyServer";
    in-out property <string> display-name: "MyServer";
    in-out property <string> map-name: "TheIsland_WP";
    in-out property <string> install-location: "MyServer";
    in-out property <bool> use-relative-path: true;
    in-out property <string> session-name: "ARKSA Server";
    in-out property <int> max-players: 10;
    in-out property <int> game-port: 7777;
    in-out property <int> query-port: 27015;
    in-out property <bool> rcon-enabled: true;
    in-out property <int> rcon-port: 27020;
    in-out property <string> admin-password: "";
    in-out property <string> server-password: "";
    in-out property <string> mods-csv: "";
    in-out property <string> extra-flags: "-log -NoBattlEye";

    in property <string> validation-error: "";
    in property <bool> busy: false;

    callback create-profile();
    callback regenerate-password();
    callback cancel-clicked();
    callback choose-map(int);

    ScrollView {
        VerticalBox {
            padding: 14px;
            spacing: 10px;

            GroupBox {
                title: "Identity";
                VerticalBox {
                    spacing: 6px;
                    HorizontalBox {
                        Text { text: "File name:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.profile-name;
                            placeholder-text: "MyServer (becomes <name>.ini)";
                            horizontal-stretch: 1;
                        }
                    }
                    HorizontalBox {
                        Text { text: "Display name:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.display-name;
                            placeholder-text: "Shown in the picker";
                            horizontal-stretch: 1;
                        }
                    }
                }
            }

            GroupBox {
                title: "Map and install location";
                VerticalBox {
                    spacing: 6px;
                    HorizontalBox {
                        Text { text: "Quick pick:"; vertical-alignment: center; min-width: 130px; }
                        ComboBox {
                            model: root.map-suggestions;
                            horizontal-stretch: 1;
                            selected => { root.choose-map(self.current-index); }
                        }
                    }
                    HorizontalBox {
                        Text { text: "Map name:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.map-name;
                            placeholder-text: "TheIsland_WP";
                            horizontal-stretch: 1;
                        }
                    }
                    HorizontalBox {
                        Text { text: "Install location:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.install-location;
                            placeholder-text: "MyServer (under ARKSA dir if relative)";
                            horizontal-stretch: 1;
                        }
                    }
                    HorizontalBox {
                        Rectangle { width: 130px; }
                        CheckBox {
                            text: "Use path relative to ARKSA dir";
                            checked <=> root.use-relative-path;
                        }
                    }
                }
            }

            GroupBox {
                title: "Server";
                VerticalBox {
                    spacing: 6px;
                    HorizontalBox {
                        Text { text: "Session name:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.session-name;
                            horizontal-stretch: 1;
                        }
                    }
                    HorizontalBox {
                        Text { text: "Max players:"; vertical-alignment: center; min-width: 130px; }
                        SpinBox {
                            value <=> root.max-players;
                            minimum: 1;
                            maximum: 200;
                        }
                    }
                    HorizontalBox {
                        Text { text: "Game port:"; vertical-alignment: center; min-width: 130px; }
                        SpinBox {
                            value <=> root.game-port;
                            minimum: 1;
                            maximum: 65535;
                        }
                        Text { text: "Query:"; vertical-alignment: center; }
                        SpinBox {
                            value <=> root.query-port;
                            minimum: 1;
                            maximum: 65535;
                        }
                    }
                    HorizontalBox {
                        Rectangle { width: 130px; }
                        CheckBox {
                            text: "Enable RCON";
                            checked <=> root.rcon-enabled;
                        }
                        SpinBox {
                            value <=> root.rcon-port;
                            minimum: 1;
                            maximum: 65535;
                            enabled: root.rcon-enabled;
                        }
                    }
                }
            }

            GroupBox {
                title: "Passwords";
                VerticalBox {
                    spacing: 6px;
                    HorizontalBox {
                        Text { text: "Admin (RCON):"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.admin-password;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Generate";
                            clicked => { root.regenerate-password(); }
                        }
                    }
                    HorizontalBox {
                        Text { text: "Server:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.server-password;
                            placeholder-text: "(optional, for joining)";
                            horizontal-stretch: 1;
                        }
                    }
                }
            }

            GroupBox {
                title: "Mods and extra flags";
                VerticalBox {
                    spacing: 6px;
                    HorizontalBox {
                        Text { text: "Mods (IDs):"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.mods-csv;
                            placeholder-text: "12345, 67890";
                            horizontal-stretch: 1;
                        }
                    }
                    HorizontalBox {
                        Text { text: "Extra flags:"; vertical-alignment: center; min-width: 130px; }
                        LineEdit {
                            text <=> root.extra-flags;
                            placeholder-text: "-log -NoBattlEye";
                            horizontal-stretch: 1;
                        }
                    }
                }
            }

            if root.validation-error != "": Text {
                text: root.validation-error;
                color: #c62828;
                wrap: word-wrap;
            }

            HorizontalBox {
                alignment: end;
                spacing: 8px;
                Button {
                    text: "Cancel";
                    enabled: !root.busy;
                    clicked => { root.cancel-clicked(); }
                }
                Button {
                    text: "Create";
                    enabled: !root.busy;
                    primary: true;
                    clicked => { root.create-profile(); }
                }
            }
        }
    }
}
